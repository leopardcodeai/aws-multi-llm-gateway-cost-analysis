# ===========================================
# LLM Gateway - Environment Configuration
# ===========================================
# Copy this to .env and fill in your values
# NEVER commit .env to version control!
# ===========================================

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
# Or use IAM roles (recommended for EC2/ECS/Lambda)

# Bedrock Model IDs (verify in your region)
BEDROCK_CLASSIFIER_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_LLAMA_8B=meta.llama3-1-8b-instruct-v1:0
BEDROCK_LLAMA_70B=meta.llama3-1-70b-instruct-v1:0
BEDROCK_LLAMA_SCOUT=meta.llama4-scout-17b-instruct-v1:0
BEDROCK_CLAUDE_SONNET=anthropic.claude-3-5-sonnet-20241022-v2:0

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_ORG_ID=org-your-org-id

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_HTTPS=false

# DynamoDB Configuration
DYNAMODB_TABLE=llm-gateway-tenants
DYNAMODB_REGION=us-east-1

# Gateway Configuration
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_WORKERS=4
LOG_LEVEL=INFO

# Auth Configuration
API_KEY_PREFIX=llmgw_
DEFAULT_MONTHLY_QUOTA=100000
DEFAULT_DAILY_REQUESTS=1000

# Dashboard Configuration
DASHBOARD_TYPE=streamlit
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501

# Observability
PROMETHEUS_PORT=9090
ENABLE_TRACING=false
JAEGER_ENDPOINT=

# Embedding Model (for semantic cache)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2